# Flask Configuration
FLASK_CONFIG=development
SECRET_KEY=your-secret-key-here

# Azure Data Lake Storage Configuration
AZURE_STORAGE_CONNECTION_STRING=your_connection_string_here
AZURE_CONTAINER_NAME=compliance-documents

# Database Configuration
DATABASE_URL=sqlite:///compliance.db

# Dev database override (used when FLASK_CONFIG=development)
DEV_DATABASE_URL=sqlite:///compliance_dev.db

# Email (SMTP) - Using adam@cenaris.com.au (existing licensed account)
MAIL_SERVER=smtp.office365.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=adam@cenaris.com.au
MAIL_PASSWORD=your-password-or-app-password-here
MAIL_DEFAULT_SENDER=adam@cenaris.com.au

# Email verification - Recommended in production
REQUIRE_EMAIL_VERIFICATION=false

# CAPTCHA (Cloudflare Turnstile) - Optional
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ============================================================================
# MILESTONE 2: SYSTEM LOGGING (Azure Application Insights)
# ============================================================================

# Azure Application Insights Connection String
# Get this from: Azure Portal → Your Application Insights Resource → Overview → Connection String
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=xxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx;IngestionEndpoint=https://xxxxx.applicationinsights.azure.com/

# Logging Configuration
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=90

# Alert Configuration (Free code-based email alerts)
ALERTS_ENABLED=false
ALERT_EMAILS=adam@cenaris.com.au

# ============================================================================

# Azure OpenAI (LLM)
# Use the BASE endpoint only (no /openai/deployments/... path)
AZURE_OPENAI_ENDPOINT=https://cenaris-ai-core-aue.openai.azure.com

# Use either Key 1 or Key 2 from Azure portal. Keep the other for key rotation.
AZURE_OPENAI_API_KEY=replace-with-your-azure-openai-key

# App code defaults to 2024-10-21; keep this unless you upgrade code + tests together.
AZURE_OPENAI_API_VERSION=2024-10-21

# Current setup: one deployment (gpt-4o-mini)
# Keep legacy deployment var populated so policy-draft checks pass even without writer model.
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_CHAT_DEPLOYMENT_MINI=gpt-4o-mini
AZURE_OPENAI_CHAT_DEPLOYMENT_WRITER=

AZURE_OPENAI_TIMEOUT_SECONDS=60
AZURE_OPENAI_SUMMARY_MAX_OUTPUT_TOKENS=450
AZURE_OPENAI_POLICY_MAX_OUTPUT_TOKENS=1400

# Enable only when you want policy drafting to call LLM.
POLICY_DRAFT_USE_LLM=false

# ============================================================================

# OAuth - Optional
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common
