{
  "info": {
    "name": "Cenaris Public API",
    "description": "Versioned public API collection for Cenaris (/api/v1).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "email", "value": "admin@example.com" },
    { "key": "password", "value": "ChangeMe123!" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "apiKey", "value": "" },
    { "key": "orgId", "value": "1" },
    { "key": "docId", "value": "1" },
    { "key": "keyId", "value": "1" },
    { "key": "webhookId", "value": "1" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', body.access_token || '');",
                  "  pm.collectionVariables.set('refreshToken', body.refresh_token || '');",
                  "  pm.collectionVariables.set('orgId', String(body.organization_id || ''));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/refresh"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Organizations",
      "item": [
        {
          "name": "List Organizations",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/organizations"
          }
        },
        {
          "name": "Get Organization",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/organizations/{{orgId}}"
          }
        },
        {
          "name": "Create Organization",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Demo Org via API\",\n  \"industry\": \"NDIS\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/organizations"
          }
        }
      ]
    },
    {
      "name": "Documents",
      "item": [
        {
          "name": "List Documents",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/documents"
          }
        },
        {
          "name": "Get Document",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/documents/{{docId}}"
          }
        },
        {
          "name": "Update Document Metadata",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"filename\": \"updated-name.pdf\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/documents/{{docId}}"
          }
        },
        {
          "name": "Delete Document",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/documents/{{docId}}"
          }
        },
        {
          "name": "Download Document",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/documents/{{docId}}/download"
          }
        }
      ]
    },
    {
      "name": "Compliance",
      "item": [
        {
          "name": "Compliance Summary",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/compliance/summary"
          }
        }
      ]
    },
    {
      "name": "Reports",
      "item": [
        {
          "name": "Generate Gap Analysis Report",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/reports/generate/gap-analysis"
          }
        }
      ]
    },
    {
      "name": "API Keys",
      "item": [
        {
          "name": "List API Keys",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/api-keys"
          }
        },
        {
          "name": "Create API Key",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"integration-key\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/api-keys"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  if (body.secret) pm.collectionVariables.set('apiKey', body.secret);",
                  "  if (body.api_key && body.api_key.id) pm.collectionVariables.set('keyId', String(body.api_key.id));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Revoke API Key",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/api-keys/{{keyId}}"
          }
        }
      ]
    },
    {
      "name": "Webhooks",
      "item": [
        {
          "name": "List Webhooks",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/webhooks"
          }
        },
        {
          "name": "Create Webhook",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Audit Trail Receiver\",\n  \"target_url\": \"https://example.com/webhooks/cenaris\",\n  \"events\": [\"document.created\", \"report.generated\"]\n}"
            },
            "url": "{{baseUrl}}/api/v1/webhooks"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  if (body.webhook && body.webhook.id) pm.collectionVariables.set('webhookId', String(body.webhook.id));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Send Test Webhook",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/webhooks/{{webhookId}}/test"
          }
        },
        {
          "name": "Delete Webhook",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/webhooks/{{webhookId}}"
          }
        }
      ]
    },
    {
      "name": "Versioning and Docs",
      "item": [
        {
          "name": "List API Versions",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/versions"
          }
        },
        {
          "name": "OpenAPI JSON",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/docs/openapi.json"
          }
        }
      ]
    }
  ]
}
